FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends sqlite3 curl && \
    rm -rf /var/lib/apt/lists/*

# Install Python dependencies for the victim agent
RUN pip install --no-cache-dir aiohttp anthropic pyyaml

# Create victim home directory structure
RUN mkdir -p /home/victim/.ssh \
             /home/victim/.aws \
             /home/victim/.github/workflows \
             /home/victim/docs \
             /home/victim/data \
             /home/victim/src/config \
             /home/victim/deploy \
             /home/victim/db

# Copy the victim entrypoint script
COPY victim_entrypoint.py /opt/victim/victim_entrypoint.py

# Create non-root victim user
RUN groupadd -r victim && \
    useradd -r -g victim -d /home/victim -s /bin/bash victim && \
    chown -R victim:victim /home/victim /opt/victim

USER victim
WORKDIR /home/victim

EXPOSE 8080

ENTRYPOINT ["python", "/opt/victim/victim_entrypoint.py"]
